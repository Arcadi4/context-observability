{
  "name": "@4rcadia/opencode-context-observability",
  "version": "0.1.0",
  "description": "Break down your context usage in OpenCode.",
  "type": "module",
  "license": "MIT",
  "author": "4rcadia",
  "repository": {
    "type": "git",
    "url": "https://github.com/arcadi4/context-observability.git"
  },
  "homepage": "https://github.com/arcadi4/context-observability",
  "bugs": {
    "url": "https://github.com/arcadi4/context-observability/issues"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "context",
    "ai",
    "agent",
    "llm"
  ],
  "main": "./src/server.ts",
  "exports": {
    ".": "./src/server.ts",
    "./server": {
      "default": "./src/server.ts",
      "config": "./plugin-options.json"
    },
    "./tui": {
      "default": "./src/tui.tsx",
      "config": "./plugin-options.json"
    }
  },
  "files": [
    "src",
    "README.md",
    "plugin-options.json"
  ],
  "engines": {
    "bun": ">=1.3.13",
    "opencode": ">=1.14.22"
  },
  "scripts": {
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test",
    "check": "bun run typecheck && bun test"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.14.22",
    "typescript": "^5.9.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.14.22",
    "@opentui/core": "^0.1.102",
    "@opentui/solid": "^0.1.102",
    "@types/bun": "latest",
    "typescript": "^6.0.3"
  }
}
